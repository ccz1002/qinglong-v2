# ============================================
# 全量部署（已迁移到 Dockerfile.full + CI 自动构建后端）
# 此文件保留兼容，如需全量构建请使用 Dockerfile.full
# ============================================
FROM whyour/qinglong:latest

# 全量替换后端（需先执行: cd ../qinglong && npm run build:back）
COPY static/build /ql/static/build

# 替换前端
COPY dist /ql/static/dist
