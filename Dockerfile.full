# ============================================
# 全量部署 Dockerfile
# 替换所有代码（前端dist + 后端build），数据库保持不动（/ql/data 走 Volume）
# 后端使用仓库内预编译的 backend-build/
# ============================================

FROM whyour/qinglong:latest

# 1. 全量替换后端编译代码（含自定义菜单管理模块）
COPY backend-build /ql/static/build

# 2. 替换前端静态资源
COPY dist /ql/static/dist
